# Mobile app connection config — copy to .env and fill in your values.
#
# PHYSICAL DEVICE NOTES:
#   - Use the Mac's Wi-Fi LAN IP (ipconfig getifaddr en0), NOT a .test host
#   - Do NOT use 127.0.0.1 — that's loopback-only on the Mac
#   - Port 8080 is taken by another project; serve project_manager on 8090
#   - Start the backend from the project root:
#       php artisan serve --host=0.0.0.0 --port=8090
#   - Then generate env.json and run Flutter:
#       bash gen_env.sh && flutter run --dart-define-from-file=env.json
#   - IP changes with DHCP — update API_BASE_URL_LAN here and re-run gen_env.sh
#   - No API_HOST needed: artisan serve + IdentifyTenant resolves tenant from
#     the X-Tenant-Subdomain header on a bare-IP host

# Active environment: lan | prod
ENV=lan

# LAN (local dev on physical device — update IP with: ipconfig getifaddr en0)
API_BASE_URL_LAN=http://192.168.x.x:8090
API_TENANT_LAN=project_manager

# Production
API_BASE_URL_PROD=https://spa.astraqatar.com
API_TENANT_PROD=spa
