<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox disabled for local debug builds so flutter_secure_storage can
	     reach the macOS Keychain without an Apple development signing certificate.
	     Release.entitlements keeps the sandbox; for a sandboxed signed build, enable
	     development signing and add a keychain-access-groups entitlement. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
