# Base URL of the catalog API (Laravel project_manager, /api/v1)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Tenant subdomain — sent as X-Tenant-Subdomain header AND ?tenant= query param
# (required: the API 404s when no tenant can be resolved)
VITE_TENANT=demo

# Branding / display
VITE_STORE_NAME=TREADHOUSE
VITE_CURRENCY=USD
