# Local dev API override — read by AppConfig.resolve() (lib/shared/domain/constants/app_config.dart).
# Priority: --dart-define (release builds) > this file > saved in-app override > fallback.
# Edit and hot-restart (not hot reload) to pick up changes.

API_BASE_URL=https://project_manager.test
API_TENANT=project_manager

# LAN (local dev on physical device — update IP with: ipconfig getifaddr en0)
API_BASE_URL_LAN=http://192.168.68.104:8090
API_TENANT_LAN=project_manager

# Set true to use the LAN values above instead of API_BASE_URL/API_TENANT.
USE_LAN_API=false
