# API Configuration
API_BASE_URL=https://primedemo.astraqatar.com
API_VERSION=v1

# LAN Configuration (for local development on physical devices)
# Update IP with: ipconfig getifaddr en0
API_BASE_URL_LAN=http://192.168.68.104:8090
API_TENANT_LAN=project_manager

# App Configuration
APP_NAME=FixMate
APP_VERSION=1.0.0

# Feature Flags
ENABLE_BIOMETRIC_LOGIN=true
ENABLE_OFFLINE_MODE=true
ENABLE_RECEIPT_PRINTING=true
USE_LAN_API=false

# Logging
ENABLE_LOGGING=true
LOG_LEVEL=debug
